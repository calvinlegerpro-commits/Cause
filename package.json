{
  "name": "causer",
  "private": true,
  "version": "0.3.0",
  "description": "Dictée vocale locale — simple et rapide",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:causerdev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build:causerdev": "tauri build --config src-tauri/tauri.dev.conf.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write . && cd src-tauri && cargo fmt",
    "format:check": "prettier --check . && cd src-tauri && cargo fmt -- --check",
    "format:frontend": "prettier --write .",
    "format:backend": "cd src-tauri && cargo fmt",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "check:translations": "bun scripts/check-translations.ts",
    "postinstall": "bun scripts/check-nix-deps.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-sql": "~2.3.2",
    "@tauri-apps/plugin-store": "~2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "geist": "^1.7.0",
    "i18next": "^25.10.10",
    "immer": "^11.1.4",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6",
    "react-select": "^5.10.2",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2",
    "tauri-plugin-macos-permissions-api": "2.3.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-select": "^5.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.6.3",
    "vite": "^6.4.1"
  }
}
